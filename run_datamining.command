#!/bin/bash

# 스크립트가 위치한 디렉토리로 이동 (더블 클릭 실행 시 중요)
cd "$(dirname "$0")"

echo "========================================="
echo "  Discord Datamining Daemon Starting...  "
echo "========================================="

# 도커 컨테이너 빌드 및 실행 (기존 컨테이너가 있으면 재시작)
docker-compose up --build -d

echo ""
echo "========================================="
echo " 데몬이 백그라운드에서 실행되었습니다! "
echo " 터미널을 종료해도 봇은 계속 돌아갑니다."
echo " 실시간 로그를 보려면 아래 명령어를 입력하세요:"
echo " docker-compose logs -f"
echo "========================================="
echo ""

# 사용자가 메시지를 읽을 수 있도록 잠시 대기
read -p "종료하려면 아무 키나 누르세요..."
